<% content_for :title, "Sign in" %>

<%
  if flash[:alert].present?
    resource.errors.add(:base, flash[:alert])
  end
%>

<div class="govuk-grid-row govuk-body">
  <div class="govuk-grid-column-two-thirds">

    <section class="govuk-notification-banner" aria-labelledby="govuk-notification-banner-title" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title" id="govuk-notification-banner-title">
          <%= t("devise.sessions.new.fcerm_banner.title") %>
        </h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-notification-banner__heading">
          <%= t("devise.sessions.new.fcerm_banner.message_html",
                link: link_to(
                  t("devise.sessions.new.fcerm_banner.link_text"),
                  t("devise.sessions.new.fcerm_banner.link_url"),
                  class: "govuk-notification-banner__link",
                  target: "_blank",
                  rel: "noopener noreferrer"
                )) %>
        </p>
      </div>
    </section>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render partial: "pafs_core/error_summary", locals: { f: f } %>

      <h1 class="govuk-heading-l">Sign in</h2>
      <div class="form-group">
        <%= f.govuk_email_field :email, autocomplete: "off", autofocus: true, width: 'one-half', label: { text: "Email address" } %>
        <%= f.govuk_password_field :password, autocomplete: "off", width: 'one-half' %>
      </div>

      <div class="form-group">
        <%= f.govuk_submit "Sign in", class: 'govuk-button' %>
      </div>

      <p><%= link_to t("reset_your_password_link"), new_password_path(resource_name) %></p>
      <p><%= link_to t("request_an_account_link"), new_account_request_path %></p>

    <% end %>
  </div>
</div>
